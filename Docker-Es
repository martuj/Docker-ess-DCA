LAB 14 : Limit CPU, Memory & Storage for Docker Container
--------------------------------------------------------
Task 1: Limit CPU & Memory

docker run -it --name resource-test --cpus="0.5" --memory="256m" busybox

# --cpus="0.5" → container can use 50% of 1 CPU
# --memory="256m" → max RAM = 256 MB

docker inspect resource-test
docker stats

Task 2: Simulate High CPU Usage

docker run -d --name cpu-test --cpus="0.5" busybox sh -c "while true; do :; done"

docker stats

Task 3: Simulate Memory Limit

docker run -it --memory="100m" busybox

# run inside the container
dd if=/dev/zero of=/bigfile bs=1M count=200
# Container will crash / OOM (Out of Memory)

Task 4: Limit Storage (Writable Layer)
docker run -it --storage-opt size=200M ubuntu

# Test Storage Limit run inside the container
fallocate -l 300M bigfile

# The container  can only write 200 MB , Prevents disk exhaustion

Task 5: Volume Size Control

Option 1: Use LVM (Advanced)
Create logical volume with fixed size
Mount to Docker

Option 2: Use Disk Partition
mount -o size=500M tmpfs /mnt/limited

docker run -it -v /mnt/limited:/data busybox

Task 6: Combine Everything

docker run -d --name prod-container --cpus="1" --memory="512m" --storage-opt size=300M nginx

docker inspect prod-container
docker stats
